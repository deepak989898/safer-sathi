# TripJack VPS proxy — Hotel HMS (copy to /var/www/tripjack-proxy/.env)
# IMPORTANT: each key must appear ONCE. Duplicates make the last value win unpredictably.
# Use STAGING (apitest) until TripJack enables production HMS for your account.

PORT=4000

# Flights (existing)
TRIPJACK_BASE_URL=https://apitest.tripjack.com
TRIPJACK_USER_ID=613341
TRIPJACK_API_KEY=your_tripjack_api_key_here

# Hotel HMS — single base URL (staging)
TRIPJACK_HOTEL_HMS_BASE=https://apitest-hms.tripjack.com

# Optional overrides (defaults are built from TRIPJACK_HOTEL_HMS_BASE in server.js)
# TRIPJACK_HOTEL_LISTING_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/listing
# TRIPJACK_HOTEL_FETCH_STATIC_URL=https://apitest-hms.tripjack.com/hms/v3/fetch-static-hotels

# Production (only when TripJack approves live HMS — switch ALL URLs together)
# TRIPJACK_HOTEL_HMS_BASE=https://hms.tripjack.com

# DO NOT use these old names (server.js ignores them):
# TRIPJACK_HOTEL_STATIC_HOTELS_URL
# TRIPJACK_HOTEL_DELETED_HOTELS_URL
# TRIPJACK_HOTEL_NATIONALITY_URL
