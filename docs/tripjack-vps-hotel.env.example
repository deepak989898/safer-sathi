# TripJack VPS proxy — Hotel HMS (/var/www/tripjack-proxy/.env)
# Each key ONCE only. Restart: pm2 restart tripjack-proxy --update-env

PORT=4000

# Flights (existing — do not change if working)
TRIPJACK_BASE_URL=https://apitest.tripjack.com
TRIPJACK_USER_ID=613341
TRIPJACK_API_KEY=your_tripjack_api_key_here

# Hotel HMS staging (all hotel URLs derive from this in server.js)
TRIPJACK_HOTEL_HMS_BASE=https://apitest-hms.tripjack.com
TRIPJACK_HOTEL_STATIC_BASE=https://apitest-hms.tripjack.com

# Optional explicit overrides (must match TRIPJACK_HOTEL_STATIC_BASE environment)
TRIPJACK_HOTEL_FETCH_STATIC_URL=https://apitest-hms.tripjack.com/hms/v3/fetch-static-hotels
TRIPJACK_HOTEL_FETCH_STATIC_DELETED_URL=https://apitest-hms.tripjack.com/hms/v3/fetch-static-hotels/deleted
TRIPJACK_HOTEL_FETCH_MAPPING_URL=https://apitest-hms.tripjack.com/hms/v3/content/fetch-hotel-mapping
TRIPJACK_HOTEL_STATIC_DETAIL_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/static-detail
TRIPJACK_HOTEL_NATIONALITIES_URL=https://apitest-hms.tripjack.com/hms/v3/nationality-info

# Booking flow (staging)
TRIPJACK_HOTEL_LISTING_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/listing
TRIPJACK_HOTEL_PRICING_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/pricing
TRIPJACK_HOTEL_REVIEW_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/review
TRIPJACK_HOTEL_BOOK_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/book
TRIPJACK_HOTEL_BOOKING_DETAILS_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/booking-details
TRIPJACK_HOTEL_CANCEL_BOOKING_URL=https://apitest-hms.tripjack.com/hms/v3/hotel/cancel-booking
